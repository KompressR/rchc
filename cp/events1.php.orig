				$resulta = mysqli_query($db,"INSERT INTO $eventsdb (name, venue, address, price, description, unixstarttime, unixendtime) VALUES ('$mname', '$mvenue', '$maddress', '$mprice', '$mdescription', '$munixstarttime', '$munixendtime')");	
